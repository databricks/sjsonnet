# Files to ignore when syncing from google-go-jsonnet (Go test suite).
# One .jsonnet filename per line. Lines starting with '#' are comments.
# Corresponding .golden files are also automatically ignored.

# std.thisFile returns paths relative to the execution context.
# go-jsonnet's test harness runs from testdata/, so std.thisFile returns
# "testdata/std.thisFile" instead of "std.thisFile.jsonnet".
# These goldens are environment-specific and must be generated by sjsonnet.
std.thisFile.jsonnet
std.thisFile2.jsonnet

# stdlib_smoke_test.jsonnet.golden also contains std.thisFile output
# which differs between go-jsonnet's and sjsonnet's test harness paths.
stdlib_smoke_test.jsonnet

# sjsonnet renders 1.42 as "1.42" (shortest round-trip representation),
# while go-jsonnet v0.22.0 renders it as "1.4199999999999999".
# Both are valid JSON representations of the same float64 value.
# sjsonnet's rendering is more user-friendly; keep our golden.
builtin_escapeStringJson.jsonnet
builtin_manifestTomlEx.jsonnet

# std.pow(1.1, 7447.081) near MaxFloat64: sjsonnet and jrsonnet agree on
# the integer rendering (trailing zeros), while go-jsonnet produces more
# significant digits. This is a rendering precision difference.
pow6.jsonnet

# std.parseYaml("---") returns null in sjsonnet (single null document)
# vs [null] in go-jsonnet (multi-doc stream with one null document).
# This is a YAML parser behavioral difference that requires a code fix.
parseYaml.jsonnet
